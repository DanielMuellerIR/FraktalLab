<IfModule mod_headers.c>
    # Diese Header sind zwingend erforderlich, damit WebAssembly (SharedArrayBuffer) funktioniert.
    # Sie entsprechen den Einstellungen aus netlify.toml
    Header set Cross-Origin-Opener-Policy "same-origin"
    Header set Cross-Origin-Embedder-Policy "credentialless"
</IfModule>

# Tracker-Dateien als Binär ausliefern.
# .dat-Erweiterung bleibt aus Historiegründen unterstützt. .mod ist die
# eigentliche kanonische Endung für ProTracker-Dateien — Apache hat dafür
# per Default keinen MIME-Type, daher hier expliziter Eintrag, damit der
# Browser den Body als ArrayBuffer bekommt und nicht als Text interpretiert.
<IfModule mod_mime.c>
    AddType application/octet-stream .dat
    AddType application/octet-stream .mod
</IfModule>
<FilesMatch "\.(dat|mod)$">
    SetEnv no-gzip 1
    Header unset Content-Encoding
</FilesMatch>

<IfModule mod_rewrite.c>
    # SPA-Routing: unbekannte Pfade auf index.html im selben Verzeichnis umleiten.
    # Relativer Pfad "index.html" (kein führender Slash!) wird von Apache relativ
    # zum Verzeichnis dieser .htaccess aufgelöst → funktioniert in jedem Unterordner.
    RewriteEngine On
    RewriteRule ^index\.html$ - [L]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.html [L]
</IfModule>
