<IfModule mod_headers.c>
    # Diese Header sind zwingend erforderlich, damit WebAssembly (SharedArrayBuffer) funktioniert.
    # Sie entsprechen den Einstellungen aus netlify.toml
    Header set Cross-Origin-Opener-Policy "same-origin"
    Header set Cross-Origin-Embedder-Policy "credentialless"
</IfModule>

# .mod.bin Tracker-Dateien als Binär ausliefern
<IfModule mod_mime.c>
    AddType application/octet-stream .bin
</IfModule>
# Keine Encoding-Manipulation für Binärdateien
<FilesMatch "\.bin$">
    SetEnv no-gzip 1
    Header unset Content-Encoding
</FilesMatch>

<IfModule mod_rewrite.c>
    # Falls du React/React-Router nutzt (SPA), leitet dies alle Anfragen auf die index.html um
    RewriteEngine On
    RewriteBase /
    RewriteRule ^index\.html$ - [L]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule . /index.html [L]
</IfModule>
